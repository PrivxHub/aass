local function MetniTemizle(Metin)
    if not Metin then return "" end
    return string.gsub(Metin, "[%c%s]", "")
end

local function AnahtariKontrolEt(GirilenKey)
    local Basarili, Sonuc = pcall(function()
        return game:HttpGet(GitHubRawLink)
    end)
    
    if not Basarili or Sonuc == "" then
        return false, "Bağlantı Hatası: GitHub okunamadı.", nil
    end

    local SuAnkiSaniye = os.time()
    local TemizGirilenKey = MetniTemizle(GirilenKey)

    for Satir in string.gmatch(Sonuc, "[^\r\n]+") do
        local Parcalar = string.split(Satir, ":")
        if #Parcalar >= 2 then
            local DosyadakiKey = MetniTemizle(Parcalar[1])
            local BitisSaniyesiMetni = MetniTemizle(Parcalar[2])
            
            if DosyadakiKey == TemizGirilenKey and BitisSaniyesiMetni ~= "" then
                local BitisSaniyesi = tonumber(BitisSaniyesiMetni)
                
                if BitisSaniyesi then
                    if SuAnkiSaniye < BitisSaniyesi then
                        local KalanSaniye = BitisSaniyesi - SuAnkiSaniye
                        local KalanSaat = math.floor(KalanSaniye / 3600)
                        local KalanDakika = math.floor((KalanSaniye % 3600) / 60)
                        return true, "Geçerli", KalanSaat .. " saat " .. KalanDakika .. " dk"
                    else
                        return false, "Bu anahtarın süresi dolmuş!", nil
                    end
                end
            end
        end
    end
    return false, "Geçersiz veya hatalı anahtar!", nil
end

